generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// Site Settings
// ──────────────────────────────────────────────
model SiteSettings {
  id              String   @id @default(cuid())
  siteName        String   @default("EduQuiz Pro")
  logoUrl         String?
  faviconUrl      String?
  metaTitle       String?
  metaDescription String?
  contactEmail    String?
  contactPhone    String?
  whatsappLink    String?
  telegramLink    String?
  rateAppEnabled  Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ──────────────────────────────────────────────
// Categories
// ──────────────────────────────────────────────
model Category {
  id          String   @id @default(cuid())
  title       String
  description String?
  iconUrl     String?
  iconType    String   @default("emoji") // "image"|"emoji"|"svg"
  categoryType String  @default("mcq")  // "mcq"|"syllabus"|"updates"|"daily_test"|"daily_result"|"previous_papers"|"mock_test"|"jobs"
  colorCode   String   @default("#ef4444")
  displayOrder Int     @default(0)
  isActive    Boolean  @default(true)
  isNew       Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courses Course[]
}

// ──────────────────────────────────────────────
// Courses
// ──────────────────────────────────────────────
model Course {
  id          String   @id @default(cuid())
  categoryId  String
  name        String
  description String?
  imageUrl    String?
  courseCode  String?
  displayOrder Int     @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category      Category      @relation(fields: [categoryId], references: [id])
  subjects      Subject[]
  syllabus      Syllabus[]
  dailyTests    DailyTest[]
  mockTests     MockTest[]
  previousPapers PreviousPaper[]
  results       Result[]
}

// ──────────────────────────────────────────────
// Subjects
// ──────────────────────────────────────────────
model Subject {
  id          String   @id @default(cuid())
  courseId    String
  name        String
  nameHindi   String?
  description String?
  subjectCode String?
  iconUrl     String?
  displayOrder Int     @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course        Course        @relation(fields: [courseId], references: [id])
  sets          Set[]
  previousPapers PreviousPaper[]
}

// ──────────────────────────────────────────────
// Sets (Question Sets / Practice Sets)
// ──────────────────────────────────────────────
model Set {
  id              String   @id @default(cuid())
  subjectId       String
  title           String
  titleHindi      String?
  description     String?
  totalQuestions  Int
  durationMinutes Int?
  difficulty      String   @default("medium") // "easy"|"medium"|"hard"
  isLocked        Boolean  @default(false)
  unlockType      String   @default("free")   // "free"|"ad_based"|"premium"
  displayOrder    Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subject   Subject    @relation(fields: [subjectId], references: [id])
  questions Question[]
}

// ──────────────────────────────────────────────
// Questions (for Sets)
// ──────────────────────────────────────────────
model Question {
  id               String   @id @default(cuid())
  setId            String
  questionText     String
  questionType     String   @default("mcq")    // "mcq"|"true_false"|"fill_blank"
  optionA          String?
  optionB          String?
  optionC          String?
  optionD          String?
  correctAnswer    String                      // "A"|"B"|"C"|"D"
  explanation      String?
  explanationImageUrl String?
  difficulty       String   @default("medium") // "easy"|"medium"|"hard"
  marks            Int      @default(1)
  negativeMarks    Int      @default(0)
  displayOrder     Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  set Set @relation(fields: [setId], references: [id])
}

// ──────────────────────────────────────────────
// Syllabus
// ──────────────────────────────────────────────
model Syllabus {
  id            String   @id @default(cuid())
  courseId      String
  title         String
  description   String?
  fileType      String   @default("pdf")      // "pdf"|"link"|"video"
  fileUrl       String?
  externalLink  String?
  isDownloadable Boolean @default(true)
  badgeColor    String?
  badgeText     String?
  displayOrder  Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  course Course @relation(fields: [courseId], references: [id])
}

// ──────────────────────────────────────────────
// Update Sections & Items
// ──────────────────────────────────────────────
model UpdateSection {
  id          String        @id @default(cuid())
  title       String
  iconUrl     String?
  displayOrder Int          @default(0)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  items UpdateItem[]
}

model UpdateItem {
  id            String        @id @default(cuid())
  sectionId     String
  title         String
  subtitle      String?
  description   String?
  status        String        @default("open")   // "open"|"coming_soon"|"expired"|"released"
  publishedDate DateTime
  expiryDate    DateTime?
  imageUrl      String?
  displayOrder  Int           @default(0)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  section UpdateSection @relation(fields: [sectionId], references: [id])
  buttons  UpdateButton[]
}

model UpdateButton {
  id           String   @id @default(cuid())
  itemId       String
  label        String
  buttonType   String   @default("link")       // "link"|"action"|"modal"
  url          String?
  action       String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  item UpdateItem @relation(fields: [itemId], references: [id])
}

// ──────────────────────────────────────────────
// Daily Tests
// ──────────────────────────────────────────────
model DailyTest {
  id              String   @id @default(cuid())
  courseId        String
  testDate        DateTime
  language        String   @default("hindi")    // "hindi"|"english"
  totalQuestions  Int
  durationMinutes Int
  isLocked        Boolean  @default(false)
  unlockType      String   @default("free")     // "free"|"ad_based"
  allowRetake     Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  course    Course         @relation(fields: [courseId], references: [id])
  questions DailyQuestion[]
}

model DailyQuestion {
  id             String   @id @default(cuid())
  testId         String
  questionText   String
  optionA        String?
  optionB        String?
  optionC        String?
  optionD        String?
  correctAnswer  String   // "A"|"B"|"C"|"D"
  explanation    String?
  marks          Int      @default(1)
  negativeMarks  Int      @default(0)
  displayOrder   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  test DailyTest @relation(fields: [testId], references: [id])
}

// ──────────────────────────────────────────────
// Mock Tests
// ──────────────────────────────────────────────
model MockTest {
  id               String   @id @default(cuid())
  courseId         String
  title            String
  description      String?
  totalQuestions   Int
  durationMinutes  Int
  fullMock         Boolean  @default(true)
  shuffleQuestions Boolean  @default(true)
  showAnswersAfter Boolean  @default(true)
  allowRetake      Boolean  @default(true)
  displayOrder     Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  course    Course        @relation(fields: [courseId], references: [id])
  questions MockQuestion[]
}

model MockQuestion {
  id             String   @id @default(cuid())
  mockTestId     String
  questionText   String
  optionA        String?
  optionB        String?
  optionC        String?
  optionD        String?
  correctAnswer  String   // "A"|"B"|"C"|"D"
  explanation    String?
  marks          Int      @default(1)
  negativeMarks  Int      @default(0)
  displayOrder   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  mockTest MockTest @relation(fields: [mockTestId], references: [id])
}

// ──────────────────────────────────────────────
// Previous Papers
// ──────────────────────────────────────────────
model PreviousPaper {
  id            String   @id @default(cuid())
  courseId      String
  examYear      Int
  examMonth     String?
  title         String
  description   String?
  fileUrl       String?
  externalLink  String?
  isDownloadable Boolean  @default(true)
  subjectId     String?
  displayOrder  Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id])
  subject Subject? @relation(fields: [subjectId], references: [id])
}

// ──────────────────────────────────────────────
// User Profiles
// ──────────────────────────────────────────────
model UserProfile {
  id               String   @id @default(cuid())
  fullName         String?
  email            String?
  phone            String?
  state            String?
  district         String?
  courseId         String?
  preferredLanguage String  @default("hindi")   // "hindi"|"english"
  totalTestsTaken  Int      @default(0)
  totalScore       Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  results Result[]
}

// ──────────────────────────────────────────────
// Results
// ──────────────────────────────────────────────
model Result {
  id               String    @id @default(cuid())
  userId           String
  testId           String
  testType         String                        // "daily_test"|"practice_set"|"mock_test"
  courseId         String
  totalQuestions    Int
  correctAnswers   Int       @default(0)
  wrongAnswers     Int       @default(0)
  skippedAnswers   Int       @default(0)
  totalScore       Int       @default(0)
  percentage       Float     @default(0)
  timeTakenSeconds Int
  rank             Int?
  attemptNumber    Int       @default(1)
  status           String    @default("submitted") // "completed"|"incomplete"|"submitted"
  testDate         DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  userProfile UserProfile @relation(fields: [userId], references: [id])
  course      Course      @relation(fields: [courseId], references: [id])
}

// ──────────────────────────────────────────────
// Notifications
// ──────────────────────────────────────────────
model Notification {
  id               String    @id @default(cuid())
  title            String
  message          String?
  description      String?
  notificationType String    @default("info")   // "update"|"announcement"|"reminder"|"info"
  link             String?
  iconUrl          String?
  priority         String    @default("medium")  // "low"|"medium"|"high"
  isActive         Boolean   @default(true)
  publishedDate    DateTime  @default(now())
  expiryDate       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}
